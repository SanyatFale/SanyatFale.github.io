---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>404 - Page Not Found</title>
  </head>
  <body class="bg-black text-white font-mono min-h-screen flex items-center justify-center">
    <div class="text-center space-y-6">
      <div class="text-8xl font-bold text-purple-500">404</div>
      <h1 class="text-2xl font-semibold text-gray-300">Page not found</h1>
      <p class="text-gray-500">This page doesn't exist or has been moved.</p>
      <a href="/" class="inline-block px-6 py-3 bg-purple-600 hover:bg-purple-700 text-white rounded-lg transition-colors">
        Go home
      </a>
    </div>
  </body>
</html>
