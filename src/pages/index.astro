---
import "../styles/global.css";
import { aboutData } from '../data/aboutData.js';
import ProfilePicture from '../components/about/ProfilePicture.jsx';
import Navigation from '../components/about/Navigation.jsx';
import AnimatedAboutContent from '../components/about/AnimatedAboutContent.jsx';
import VerticalLine from '../components/about/VerticalLine.jsx';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Sanyat Fale</title>
    <meta name="description" content="Sanyat Fale — B.Tech student at IISc Bengaluru, working on ML systems, NLP, and agentic AI." />
  </head>

  <body>
    <main class="min-h-screen bg-black text-white font-mono relative overflow-hidden">

      <!-- Navigation -->
      <Navigation client:load />

      <!-- Profile Picture Component -->
      <ProfilePicture client:load />

      <!-- Vertical Line with Drop Animation -->
      <VerticalLine client:load />

      <!-- Main Content Wrapper -->
      <!-- Desktop: content starts past the photo; Mobile: full-width with normal padding -->
      <div class="relative z-10 pt-[28vh] max-lg:pt-6 pb-20">

        <div class="max-w-none pl-[32vw] pr-16 max-lg:pl-6 max-lg:pr-6">
          <AnimatedAboutContent client:load aboutData={aboutData} />
        </div>
      </div>

    </main>

    <style>
      :root {
        --purple: #a855f7;
        --gray: #6b7280;
        --bg: #000000;
        --light: #f3f4f6;
        --comment: #9ca3af;
      }

      body {
        background-color: var(--bg);
        color: var(--light);
        font-family: 'Courier New', monospace;
      }

      .text-primary-400 {
        color: var(--purple);
      }

      .text-primary-500 {
        color: var(--purple);
      }

      .bg-primary-500 {
        background-color: var(--purple);
      }

      .border-primary-500 {
        border-color: var(--purple);
      }
    </style>
  </body>
</html>
