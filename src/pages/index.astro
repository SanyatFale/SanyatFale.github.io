---
import "../styles/global.css";
import AnimatedIntro from "../components/AnimatedIntro.jsx";
import AnimatedCircle from "../components/AnimatedCircle.jsx";
import SimpleDarkModeToggle from "../components/SimpleDarkModeToggle.jsx";

// Featured projects data
const featuredProjects = [
  {
    title: "Magical Mercury Website",
    description: "A modern, responsive portfolio website built with Astro, React, and Tailwind CSS. Features dark mode, smooth animations, and a vinyl record audio player.",
    thumbnail: "/images/project-portfolio.jpg",
    status: "Live",
    tech: ["Astro", "React", "Tailwind CSS"],
    link: "/projects",
    featured: true,
    icon: "🌐"
  },
  {
    title: "PII Detection Toolkit",
    description: "A fast and customizable Java library for identifying personal data in unstructured text with high accuracy and performance.",
    thumbnail: "/images/project-pii.jpg",
    status: "Open Source",
    tech: ["Java", "NLP", "Security"],
    link: "/projects",
    featured: true,
    icon: "🔍"
  },
  {
    title: "AI Chat Assistant",
    description: "An intelligent chatbot powered by OpenAI's GPT with context awareness, memory capabilities, and natural conversation flow.",
    thumbnail: "/images/project-ai.jpg",
    status: "Live",
    tech: ["Python", "OpenAI", "FastAPI"],
    link: "/projects",
    featured: true,
    icon: "🤖"
  }
];
---

<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Digital Creator & Developer</title>
    <meta name="description" content="Welcome to my digital space - where creativity meets technology through code, design, and storytelling." />
  </head>

  <body class="bg-black text-white font-mono overflow-x-hidden">
    <!-- Background Elements -->
    <div class="fixed inset-0 -z-10">
      <!-- Pitch black background -->
      <div class="absolute inset-0 bg-black"></div>

      <!-- Floating geometric shapes -->
      <div class="absolute top-20 left-10 w-32 h-32 bg-gradient-to-r from-blue-400/20 to-purple-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-40 right-20 w-24 h-24 bg-gradient-to-r from-purple-400/20 to-pink-400/20 rounded-full blur-xl animate-pulse delay-1000"></div>
      <div class="absolute bottom-40 left-20 w-40 h-40 bg-gradient-to-r from-indigo-400/20 to-blue-400/20 rounded-full blur-xl animate-pulse delay-2000"></div>

      <!-- Grid pattern overlay -->
      <div class="absolute inset-0 opacity-30 dark:opacity-20" style="background-image: radial-gradient(circle at 1px 1px, rgba(156,146,172,0.15) 1px, transparent 0); background-size: 20px 20px;"></div>
    </div>

    <!-- Dark Mode Toggle -->
    <SimpleDarkModeToggle client:load />

    <!-- HERO SECTION -->
    <section id="hero" class="relative min-h-screen flex flex-col items-center justify-center px-6">
      <!-- Main content container -->
      <div class="max-w-6xl mx-auto text-center space-y-8">
        <!-- Animated intro component -->
        <div class="relative">
          <AnimatedIntro client:load />

          <!-- Decorative elements around intro -->
          <div class="absolute -top-8 -left-8 w-16 h-16 border-2 border-indigo-300/30 dark:border-indigo-500/30 rounded-full animate-spin-slow"></div>
          <div class="absolute -bottom-8 -right-8 w-12 h-12 border-2 border-purple-300/30 dark:border-purple-500/30 rounded-full animate-spin-slow delay-1000"></div>
        </div>

        <!-- Enhanced tagline -->
        <div class="space-y-4">
          <p class="text-xl md:text-2xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed">
            This website is still in the making... will focus on
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-purple-600 font-semibold">projects</span>,
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-pink-600 font-semibold">research</span>,
            and <span class="text-transparent bg-clip-text bg-gradient-to-r from-pink-600 to-red-600 font-semibold">compelling stories</span>
          </p>

          <!-- Stats or highlights -->
          <div class="flex flex-wrap justify-center gap-8 mt-8 text-sm text-gray-500 dark:text-gray-400">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
              <span>Undergraduate Student</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
              <span>Based in Bangalore</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 bg-purple-500 rounded-full"></div>
              <span>Machine Learning Enthusiast</span>
            </div>
          </div>
        </div>


      </div>
    </section>

    <!-- EXPLORE SECTION -->
    <section id="explore" class="relative min-h-screen flex flex-col items-center justify-center px-6 py-20">
      <!-- Background gradient for section -->
      <div class="absolute inset-0 bg-gradient-to-b from-transparent via-white/50 to-transparent dark:via-gray-800/50"></div>

      <div class="relative max-w-6xl mx-auto text-center space-y-16">
        <!-- Section header -->
        <div class="space-y-4">
          <h2 class="text-4xl md:text-5xl font-bold bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">
            Explore My Universe
          </h2>
          <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
            Dive into different facets of my work and discover the stories behind the code
          </p>
        </div>

        <!-- Enhanced navigation cards with circles inside -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
          <!-- Blog Card -->
          <div class="group relative text-center">
            <div class="absolute inset-0 bg-gradient-to-r from-blue-500 to-purple-600 rounded-2xl blur-xl opacity-20 group-hover:opacity-30 transition-opacity duration-300"></div>
            <div class="relative bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl p-8 border border-gray-200 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-600 transition-all duration-300">
              <div class="space-y-6">
                <!-- Animated Circle with text and icon -->
                <div class="flex justify-center">
                  <AnimatedCircle href="/blog" delay={0.6} client:load>
                    <div class="text-center">
                      <svg class="w-6 h-6 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                      </svg>
                      <div class="text-sm font-semibold">Blog</div>
                    </div>
                  </AnimatedCircle>
                </div>
                <div>
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">Read Stories</h3>
                  <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
                    Thoughts, tutorials, and insights on technology, creativity, and the journey of continuous learning
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- About Card -->
          <div class="group relative text-center">
            <div class="absolute inset-0 bg-gradient-to-r from-purple-500 to-pink-600 rounded-2xl blur-xl opacity-20 group-hover:opacity-30 transition-opacity duration-300"></div>
            <div class="relative bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl p-8 border border-gray-200 dark:border-gray-700 hover:border-purple-300 dark:hover:border-purple-600 transition-all duration-300">
              <div class="space-y-6">
                <!-- Animated Circle with text and icon -->
                <div class="flex justify-center">
                  <AnimatedCircle href="/about" delay={0.75} client:load>
                    <div class="text-center">
                      <svg class="w-6 h-6 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                      </svg>
                      <div class="text-sm font-semibold">About</div>
                    </div>
                  </AnimatedCircle>
                </div>
                <div>
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">My Journey</h3>
                  <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
                    Get to know the person behind the code - my journey, passions, and what drives me to create
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Projects Card -->
          <div class="group relative text-center">
            <div class="absolute inset-0 bg-gradient-to-r from-pink-500 to-red-600 rounded-2xl blur-xl opacity-20 group-hover:opacity-30 transition-opacity duration-300"></div>
            <div class="relative bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl p-8 border border-gray-200 dark:border-gray-700 hover:border-pink-300 dark:hover:border-pink-600 transition-all duration-300">
              <div class="space-y-6">
                <!-- Animated Circle with text and icon -->
                <div class="flex justify-center">
                  <AnimatedCircle href="/projects" delay={0.9} client:load>
                    <div class="text-center">
                      <svg class="w-6 h-6 mx-auto mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                      </svg>
                      <div class="text-sm font-semibold">Projects</div>
                    </div>
                  </AnimatedCircle>
                </div>
                <div>
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-2">View Work</h3>
                  <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
                    Explore my latest creations, experiments, and the tools I've built to solve real-world problems
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Featured Projects Section -->
        <div class="mt-20">
          <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4">
              Featured Projects
            </h2>
            <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
              Explore some of my recent work that showcases creativity, technical skills, and problem-solving
            </p>
          </div>

          <!-- Projects Grid -->
          <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
            {featuredProjects.map((project, index) => (
              <a href={project.link} class="block group relative bg-white/80 dark:bg-gray-800/80 backdrop-blur-sm rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-700 hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-500 hover:shadow-2xl hover:-translate-y-2 cursor-pointer">
                <div class="absolute inset-0 bg-gradient-to-br from-primary-500/10 to-purple-500/10 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

                <div class="relative aspect-video bg-gradient-to-br from-primary-500 to-purple-600 flex items-center justify-center overflow-hidden">
                  <div class="text-white text-5xl group-hover:scale-110 transition-transform duration-300">
                    {project.icon}
                  </div>
                  <div class="absolute top-3 right-3 px-2 py-1 bg-white/20 backdrop-blur-sm text-white text-xs rounded-full font-medium">
                    {project.status}
                  </div>
                </div>

                <div class="relative p-6 space-y-4">
                  <div class="flex items-center justify-between">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-white group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
                      {project.title}
                    </h3>
                  </div>

                  <p class="text-gray-600 dark:text-gray-300 leading-relaxed text-sm">
                    {project.description}
                  </p>

                  <div class="flex flex-wrap gap-2">
                    {project.tech.slice(0, 3).map(tech => (
                      <span class="px-3 py-1 bg-primary-100 dark:bg-primary-900/30 text-primary-700 dark:text-primary-300 text-xs rounded-full font-medium">
                        {tech}
                      </span>
                    ))}
                  </div>
                </div>
              </a>
            ))}
          </div>

          {/* View All Projects Link */}
          <div class="text-center mt-12">
            <a
              href="/projects"
              class="inline-flex items-center gap-2 px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white rounded-xl font-medium transition-all duration-300 hover:shadow-lg hover:-translate-y-1"
            >
              <span>View All Projects</span>
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
              </svg>
            </a>
          </div>
        </div>

        <!-- Call to action -->
        <div class="pt-16">
          <p class="text-gray-500 dark:text-gray-400 text-sm">
            Ready to collaborate? <a href="/about" class="text-indigo-600 dark:text-indigo-400 hover:underline font-medium">Let's connect</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Custom CSS for animations -->
    <style>
      @keyframes spin-slow {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
      }

      .animate-spin-slow {
        animation: spin-slow 20s linear infinite;
      }

      .scroll-indicator:hover .animate-bounce {
        animation-duration: 0.5s;
      }

      /* Smooth scrolling */
      html {
        scroll-behavior: smooth;
      }

      /* Custom scrollbar */
      ::-webkit-scrollbar {
        width: 8px;
      }

      ::-webkit-scrollbar-track {
        background: rgba(0, 0, 0, 0.1);
      }

      ::-webkit-scrollbar-thumb {
        background: linear-gradient(to bottom, #6366f1, #8b5cf6);
        border-radius: 4px;
      }

      ::-webkit-scrollbar-thumb:hover {
        background: linear-gradient(to bottom, #4f46e5, #7c3aed);
      }
    </style>

    <!-- Smooth Auto-Scroll Script -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        // Add smooth scrolling to the entire page
        document.documentElement.style.scrollBehavior = 'smooth';

        // Enhanced smooth scroll for anchor links
        const links = document.querySelectorAll('a[href^="#"]');
        links.forEach(link => {
          link.addEventListener('click', function(e) {
            e.preventDefault();
            const targetId = this.getAttribute('href').substring(1);
            const targetElement = document.getElementById(targetId);

            if (targetElement) {
              targetElement.scrollIntoView({
                behavior: 'smooth',
                block: 'start',
                inline: 'nearest'
              });
            }
          });
        });

        // Add visual feedback for scroll progress
        const progressBar = document.createElement('div');
        progressBar.style.cssText = `
          position: fixed;
          top: 0;
          left: 0;
          width: 0%;
          height: 3px;
          background: linear-gradient(to right, #6366f1, #8b5cf6, #ec4899);
          z-index: 9999;
          transition: width 0.3s ease;
        `;
        document.body.appendChild(progressBar);

        // Update progress bar smoothly
        window.addEventListener('scroll', function() {
          const scrolled = (window.scrollY / (document.documentElement.scrollHeight - window.innerHeight)) * 100;
          progressBar.style.width = Math.min(scrolled, 100) + '%';
        });
      });
    </script>

    <!-- CSS Styles for pitch black aesthetic -->
    <style>
      :root {
        --purple: #a855f7;
        --gray: #6b7280;
        --bg: #000000;
        --light: #f3f4f6;
        --comment: #9ca3af;
      }

      body {
        background-color: var(--bg) !important;
        color: var(--light) !important;
        font-family: 'Courier New', monospace !important;
      }

      .text-primary-400 {
        color: var(--purple) !important;
      }

      .text-primary-500 {
        color: var(--purple) !important;
      }

      .bg-primary-500 {
        background-color: var(--purple) !important;
      }

      .border-primary-500 {
        border-color: var(--purple) !important;
      }

      /* Override any remaining light backgrounds */
      .bg-white, .dark\:bg-gray-800, .bg-gray-50 {
        background-color: rgba(0, 0, 0, 0.8) !important;
      }

      .text-gray-900, .dark\:text-gray-100 {
        color: var(--light) !important;
      }

      /* Update card backgrounds */
      .bg-white\/80, .dark\:bg-gray-800\/80 {
        background-color: rgba(0, 0, 0, 0.6) !important;
        border-color: rgba(168, 85, 247, 0.3) !important;
      }

      /* Update borders */
      .border-gray-200, .dark\:border-gray-700 {
        border-color: rgba(168, 85, 247, 0.2) !important;
      }
    </style>
  </body>
</html>
