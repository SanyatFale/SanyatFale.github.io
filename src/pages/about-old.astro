---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>About Me</title>
  </head>
  <body class="bg-white text-gray-800 font-sans">
    <!-- Floating CV Button -->
    <a
      href="/cv/sanyat-cv.pdf"
      class="fixed top-6 right-6 z-50 bg-indigo-600 text-white px-4 py-2 rounded-full shadow-lg hover:bg-indigo-700 transition"
      download
    >
      📄 Download CV
    </a>

    <!-- About Content -->
    <main class="max-w-3xl mx-auto mt-32 px-6">
      <h1 class="text-4xl font-bold mb-6">About Me</h1>
      <p class="text-lg leading-7">
        Hi! I’m Sanyat — a curious writer, builder, and lifelong learner.
        <br /><br />
        I’m passionate about blending creativity with systems, exploring both tech and storytelling.
        <br /><br />
        This space is a playground for thoughts, projects, and personal growth.
      </p>
    </main>
  </body>
</html>
