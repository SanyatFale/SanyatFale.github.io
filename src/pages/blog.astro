---
import { getCollection } from 'astro:content';
import "../styles/global.css";

const posts = await getCollection('blog');
const publishedPosts = posts
  .filter(post => !post.slug.startsWith('_'))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

const allTags = [...new Set(publishedPosts.flatMap(post => post.data.tags || []))];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog — Sanyat Fale</title>
    <meta name="description" content="Writing on machine learning, software, and ideas." />
  </head>

  <body class="bg-black text-white font-mono">

    <!-- Navigation Header -->
    <header class="sticky top-0 z-40 bg-black/90 backdrop-blur-md border-b border-purple-900/30">
      <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center">
        <a href="/" class="font-mono text-gray-400 hover:text-purple-400 transition-colors text-sm">
          ← .home()
        </a>
      </nav>
    </header>

    <section class="max-w-4xl mx-auto px-6 py-16">
      <h1 class="text-4xl font-bold font-mono mb-12 text-white">My Blog</h1>

      <!-- Search and Filter Controls -->
      <div class="mb-10 space-y-4">
        <!-- Search Input -->
        <div class="relative">
          <input
            type="text"
            id="search-input"
            placeholder="search posts..."
            class="w-full bg-transparent border border-purple-900/40 rounded-none px-4 py-2 text-sm font-mono text-gray-300 placeholder-gray-600 focus:outline-none focus:border-purple-500 transition-colors"
          />
        </div>

        <!-- Tag Filter -->
        {allTags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            <button class="tag-filter px-3 py-1 text-xs font-mono bg-purple-600 text-white rounded-sm transition-colors" data-tag="all">
              all
            </button>
            {allTags.map(tag => (
              <button class="tag-filter px-3 py-1 text-xs font-mono bg-transparent border border-purple-900/40 text-gray-400 hover:border-purple-500 hover:text-gray-200 rounded-sm transition-colors" data-tag={tag}>
                #{tag}
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Blog Posts List -->
      <div id="posts-container" class="space-y-0">
        {publishedPosts.map((post, index) => {
          const formattedDate = new Date(post.data.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'short',
            day: 'numeric'
          });

          return (
            <article
              class="post-card border-t border-purple-900/20 py-8 group"
              data-tags={JSON.stringify(post.data.tags || [])}
              data-title={post.data.title.toLowerCase()}
            >
              <div class="flex items-start gap-6">
                <!-- Date -->
                <time class="text-xs font-mono text-gray-600 w-24 shrink-0 pt-1">
                  {formattedDate}
                </time>

                <!-- Content -->
                <div class="flex-1 min-w-0">
                  <h2 class="text-lg font-mono font-semibold text-gray-200 group-hover:text-purple-400 transition-colors mb-2">
                    <a href={`/blog/${post.slug}`}>
                      {post.data.title}
                    </a>
                  </h2>

                  <p class="text-sm text-gray-500 leading-relaxed mb-4">
                    {post.data.description}
                  </p>

                  <div class="flex items-center gap-4">
                    {post.data.tags && post.data.tags.length > 0 && (
                      <div class="flex flex-wrap gap-2">
                        {post.data.tags.map(tag => (
                          <span class="text-xs font-mono text-gray-600">#{tag}</span>
                        ))}
                      </div>
                    )}
                    {post.data.readingTime && (
                      <span class="text-xs font-mono text-gray-600">{post.data.readingTime}</span>
                    )}
                  </div>
                </div>

                <!-- Arrow -->
                <a href={`/blog/${post.slug}`} class="text-gray-700 group-hover:text-purple-400 transition-colors shrink-0 pt-1">
                  →
                </a>
              </div>
            </article>
          );
        })}
      </div>

      <!-- Empty State -->
      {publishedPosts.length === 0 && (
        <div class="py-16 text-center">
          <p class="font-mono text-gray-600">no posts yet.</p>
        </div>
      )}

      <!-- No results message -->
      <div id="no-results" class="hidden py-16 text-center">
        <p class="font-mono text-gray-600">no matching posts.</p>
      </div>
    </section>

    <!-- Contact footer -->
    <footer class="border-t border-purple-900/20 max-w-4xl mx-auto px-6 py-8">
      <p class="font-mono text-sm text-gray-600">
        questions or thoughts? <span id="blog-email-link"></span>
      </p>
    </footer>
    <script>
      (function() {
        const el = document.getElementById('blog-email-link');
        if (el) {
          const e = atob('c2FueWF0dmlub2RAaWlzYy5hYy5pbg==');
          el.innerHTML = '<a href="mailto:' + e + '" class="text-purple-400 hover:underline font-mono">' + e + '</a>';
        }
      })();
    </script>

    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
        const filterButtons = document.querySelectorAll('.tag-filter');
        const postCards = document.querySelectorAll('.post-card') as NodeListOf<HTMLElement>;
        const noResults = document.getElementById('no-results');

        let activeTag = 'all';
        let searchQuery = '';

        function filterPosts() {
          let visibleCount = 0;

          postCards.forEach(card => {
            const el = card as HTMLElement;
            const cardTags: string[] = JSON.parse(el.getAttribute('data-tags') || '[]');
            const cardTitle: string = el.getAttribute('data-title') || '';

            const tagMatch = activeTag === 'all' || cardTags.includes(activeTag);
            const searchMatch = searchQuery === '' || cardTitle.includes(searchQuery.toLowerCase());

            if (tagMatch && searchMatch) {
              el.style.display = 'block';
              visibleCount++;
            } else {
              el.style.display = 'none';
            }
          });

          if (noResults) {
            noResults.classList.toggle('hidden', visibleCount > 0);
          }
        }

        filterButtons.forEach(button => {
          button.addEventListener('click', function(e) {
            const btn = e.currentTarget as HTMLElement;
            activeTag = btn.getAttribute('data-tag') || 'all';

            filterButtons.forEach(b => {
              b.classList.remove('bg-purple-600', 'text-white');
              b.classList.add('bg-transparent', 'border', 'border-purple-900/40', 'text-gray-400');
            });
            btn.classList.add('bg-purple-600', 'text-white');
            btn.classList.remove('bg-transparent', 'text-gray-400');

            filterPosts();
          });
        });

        if (searchInput) {
          searchInput.addEventListener('input', function(e) {
            searchQuery = (e.currentTarget as HTMLInputElement).value;
            filterPosts();
          });
        }
      });
    </script>

    <style>
      :root {
        --purple: #a855f7;
        --bg: #000000;
        --light: #f3f4f6;
      }

      body {
        background-color: var(--bg);
        color: var(--light);
        font-family: 'Courier New', monospace;
      }
    </style>
  </body>
</html>
