---
import { getCollection } from 'astro:content';
import "../styles/global.css";
import DarkModeToggle from "../components/DarkModeToggle.jsx";

const posts = await getCollection('blog');
// Filter out template file and sort by date
const publishedPosts = posts
  .filter(post => !post.slug.startsWith('_'))
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime());

// Get unique tags for filtering
const allTags = [...new Set(publishedPosts.flatMap(post => post.data.tags || []))];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog - Thoughts, Stories & Ideas</title>
    <meta name="description" content="Explore my latest thoughts, tutorials, and insights on technology, creativity, and life." />
  </head>

  <body class="bg-black text-white font-mono transition-colors duration-300">
    <!-- Dark Mode Toggle -->
    <DarkModeToggle client:load />

    <!-- Navigation Header -->
    <header class="sticky top-0 z-40 bg-white/80 dark:bg-gray-900/80 backdrop-blur-md border-b border-gray-200 dark:border-gray-700">
      <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 transition-colors">
          ← Home
        </a>
        <div class="text-gray-600 dark:text-gray-300">
          {publishedPosts.length} {publishedPosts.length === 1 ? 'Post' : 'Posts'}
        </div>
      </nav>
    </header>

    <!-- Hero Section -->
    <section class="max-w-6xl mx-auto px-6 py-16">
      <div class="text-center mb-16">
        <h1 class="text-5xl md:text-6xl font-bold mb-6 bg-gradient-to-r from-gray-900 to-gray-600 dark:from-white dark:to-gray-300 bg-clip-text text-transparent">
          My Blog
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto leading-relaxed">
          Thoughts, stories, and insights on technology, creativity, and the journey of continuous learning.
        </p>
      </div>

      <!-- Tag Filter (if there are tags) -->
      {allTags.length > 0 && (
        <div class="mb-12">
          <h3 class="text-lg font-semibold mb-4 text-gray-700 dark:text-gray-300">Filter by topic:</h3>
          <div class="flex flex-wrap gap-2">
            <button class="tag-filter active px-4 py-2 text-sm bg-indigo-600 text-white rounded-full hover:bg-indigo-700 transition-colors" data-tag="all">
              All Posts
            </button>
            {allTags.map(tag => (
              <button class="tag-filter px-4 py-2 text-sm bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-full hover:bg-gray-300 dark:hover:bg-gray-600 transition-colors" data-tag={tag}>
                #{tag}
              </button>
            ))}
          </div>
        </div>
      )}

      <!-- Blog Posts Grid -->
      <div class="grid gap-8 md:gap-12" id="posts-container">
        {publishedPosts.map((post, index) => {
          const formattedDate = new Date(post.data.pubDate).toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric'
          });

          return (
            <article class="post-card group" data-tags={JSON.stringify(post.data.tags || [])}>
              <div class="grid md:grid-cols-3 gap-8 items-start">
                <!-- Thumbnail -->
                <div class="md:col-span-1">
                  {post.data.thumbnail ? (
                    <div class="aspect-video rounded-xl overflow-hidden shadow-lg group-hover:shadow-xl transition-shadow duration-300">
                      <img
                        src={post.data.thumbnail}
                        alt={post.data.title}
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      />
                    </div>
                  ) : (
                    <div class="aspect-video rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center shadow-lg group-hover:shadow-xl transition-shadow duration-300">
                      <div class="text-white text-4xl font-bold">
                        {post.data.title.charAt(0)}
                      </div>
                    </div>
                  )}
                </div>

                <!-- Content -->
                <div class="md:col-span-2">
                  <div class="flex items-center gap-4 mb-4">
                    <time class="text-sm text-gray-500 dark:text-gray-400 font-medium">
                      {formattedDate}
                    </time>
                    {post.data.readingTime && (
                      <>
                        <span class="text-gray-300 dark:text-gray-600">•</span>
                        <span class="text-sm text-gray-500 dark:text-gray-400">{post.data.readingTime}</span>
                      </>
                    )}
                    {post.data.featured && (
                      <>
                        <span class="text-gray-300 dark:text-gray-600">•</span>
                        <span class="text-sm bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 px-2 py-1 rounded-full">
                          Featured
                        </span>
                      </>
                    )}
                  </div>

                  <h2 class="text-2xl md:text-3xl font-bold mb-4 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">
                    <a href={`/blog/${post.slug}`} class="hover:underline">
                      {post.data.title}
                    </a>
                  </h2>

                  <p class="text-gray-600 dark:text-gray-300 leading-relaxed mb-6">
                    {post.data.description}
                  </p>

                  <!-- Tags -->
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 mb-6">
                      {post.data.tags.map(tag => (
                        <span class="px-3 py-1 text-sm bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 rounded-full border border-gray-200 dark:border-gray-700">
                          #{tag}
                        </span>
                      ))}
                    </div>
                  )}

                  <a
                    href={`/blog/${post.slug}`}
                    class="inline-flex items-center text-indigo-600 dark:text-indigo-400 hover:text-indigo-700 dark:hover:text-indigo-300 font-medium transition-colors"
                  >
                    Read more
                    <svg class="ml-2 w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                  </a>
                </div>
              </div>

              {index < publishedPosts.length - 1 && (
                <hr class="mt-12 border-gray-200 dark:border-gray-700" />
              )}
            </article>
          );
        })}
      </div>

      <!-- Empty State -->
      {publishedPosts.length === 0 && (
        <div class="text-center py-16">
          <div class="text-6xl mb-4">📝</div>
          <h3 class="text-2xl font-bold mb-2">No posts yet</h3>
          <p class="text-gray-600 dark:text-gray-300">Check back soon for new content!</p>
        </div>
      )}
    </section>

    <!-- Filter functionality -->
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        const filterButtons = document.querySelectorAll('.tag-filter');
        const postCards = document.querySelectorAll('.post-card');

        filterButtons.forEach(button => {
          button.addEventListener('click', function() {
            const selectedTag = this.getAttribute('data-tag');

            // Update active button
            filterButtons.forEach(btn => btn.classList.remove('active', 'bg-indigo-600', 'text-white'));
            filterButtons.forEach(btn => btn.classList.add('bg-gray-200', 'dark:bg-gray-700', 'text-gray-700', 'dark:text-gray-300'));

            this.classList.add('active', 'bg-indigo-600', 'text-white');
            this.classList.remove('bg-gray-200', 'dark:bg-gray-700', 'text-gray-700', 'dark:text-gray-300');

            // Filter posts
            postCards.forEach(card => {
              const cardTags = JSON.parse(card.getAttribute('data-tags') || '[]');

              if (selectedTag === 'all' || cardTags.includes(selectedTag)) {
                card.style.display = 'block';
              } else {
                card.style.display = 'none';
              }
            });
          });
        });
      });
    </script>

    <!-- CSS Styles for pitch black aesthetic -->
    <style>
      :root {
        --purple: #a855f7;
        --gray: #6b7280;
        --bg: #000000;
        --light: #f3f4f6;
        --comment: #9ca3af;
      }

      body {
        background-color: var(--bg) !important;
        color: var(--light) !important;
        font-family: 'Courier New', monospace !important;
      }

      .text-primary-400 {
        color: var(--purple) !important;
      }

      .text-primary-500 {
        color: var(--purple) !important;
      }

      .bg-primary-500 {
        background-color: var(--purple) !important;
      }

      .border-primary-500 {
        border-color: var(--purple) !important;
      }

      /* Override light backgrounds */
      .bg-white, .dark\:bg-gray-900, .bg-gray-50 {
        background-color: rgba(0, 0, 0, 0.8) !important;
      }

      .bg-white\/80, .dark\:bg-gray-900\/80 {
        background-color: rgba(0, 0, 0, 0.6) !important;
        border-color: rgba(168, 85, 247, 0.3) !important;
      }

      /* Update text colors */
      .text-gray-900, .dark\:text-gray-100, .text-gray-600, .dark\:text-gray-300 {
        color: var(--light) !important;
      }

      /* Update borders */
      .border-gray-200, .dark\:border-gray-700 {
        border-color: rgba(168, 85, 247, 0.2) !important;
      }

      /* Update tag styles */
      .bg-gray-100, .dark\:bg-gray-800 {
        background-color: rgba(168, 85, 247, 0.2) !important;
        color: var(--light) !important;
      }

      /* Update button styles */
      .bg-gray-200, .dark\:bg-gray-700 {
        background-color: rgba(168, 85, 247, 0.3) !important;
        color: var(--light) !important;
      }

      /* Update indigo colors to purple */
      .text-indigo-600, .dark\:text-indigo-400 {
        color: var(--purple) !important;
      }

      .bg-indigo-600 {
        background-color: var(--purple) !important;
      }

      .hover\:bg-indigo-700:hover {
        background-color: #9333ea !important;
      }
    </style>
  </body>
</html>
