---
import "../styles/global.css";

const projects = [
  {
    title: "Agentic AI for Home Energy Management",
    description: "Multivariate time-series forecasting and anomaly detection pipeline. Multi-model consensus with natural-language queries for cost prediction, carbon-aware scheduling, and load shifting. Autonomous planning across data retrieval, forecasting, optimization, and control.",
    tech: ["Python", "PyTorch", "Agentic AI", "Time Series", "LLMs"],
    category: "ai",
    status: "In Progress",
    github: "",
    paper: ""
  },
  {
    title: "Optimization of Hyperledger Fabric",
    description: "AI model predicting blockchain network performance (throughput and latency) from topology and workload parameters. DNN-based model achieving 10–15% MAPE across 15,000 benchmarks with sub-500ms inference. Built in collaboration with NPCI.",
    tech: ["Python", "PyTorch", "Hyperledger", "DNN", "Blockchain"],
    category: "ai",
    status: "Completed",
    github: "https://github.com/SanyatFale/HLF-Performance-Predictor",
    paper: "https://drive.google.com/file/d/1dtUk-HcTQw0_VhVQjwSGFVi1vpe_EP-x/view?usp=sharing"
  },
  {
    title: "StudyBuddy",
    description: "Agentic pipeline for multi-stage document analysis. Multimodal input (PDF, audio, video). Hybrid retrieval combining FAISS and BM25. MCP server architecture with RESTful API. Models: Mistral 7B, Qwen2, TinyLlama.",
    tech: ["Python", "LangChain", "RAG", "MCP", "FAISS", "LLMs"],
    category: "llm",
    status: "Completed",
    github: "https://github.com/varivashyap/Agentic-and-Generative-AI-Project",
    paper: ""
  },
  {
    title: "Multi-Hop Question Answering",
    description: "Intelligent system for connecting information across multiple documents using DistilBERT with boundary prediction. Achieved 0.7025 F1 score (12% improvement) on HotpotQA's 113K question pairs.",
    tech: ["Python", "PyTorch", "Transformers", "DistilBERT", "NLP"],
    category: "nlp",
    status: "Completed",
    github: "https://github.com/SanyatFale/MultiHopQA",
    paper: "https://drive.google.com/file/d/1X6Lm_2Q5VQLn8KH5Je2IO9cOkDBb5u5r/view?usp=sharing"
  },
  {
    title: "Robust Speech Recognition",
    description: "Speech recognition system for noisy environments (SNR −20 to +20 dB) using tri-view contrastive learning with multi-positive InfoNCE loss. Transformer encoder trained on LibriSpeech + MUSAN.",
    tech: ["Python", "PyTorch", "Transformers", "Contrastive Learning", "Audio"],
    category: "nlp",
    status: "Completed",
    github: "https://github.com/SanyatFale/Robust_Speech_Recognition",
    paper: "https://drive.google.com/file/d/1XlAEAvDlc4EJsCaIvOKcf5xPiC2hp00t/view?usp=sharing"
  },
  {
    title: "Bird Scout",
    description: "AI tool for bird species identification from visual and audio inputs. 95% classification accuracy using Faster R-CNN. Audio identification via Mel spectrogram analysis. LLM-powered chatbot using Gemini 1.5 API with RAG.",
    tech: ["Python", "Computer Vision", "Faster R-CNN", "Gemini", "RAG"],
    category: "cv",
    status: "Completed",
    github: "https://github.com/Nagasai561/Bird_Scouts",
    paper: ""
  },
  {
    title: "Self-Supervised Visual Representations",
    description: "Investigating self-supervised visual representations using MoCo framework. Evaluated contrastive learning performance on CIFAR-10 and analyzed learned feature quality across training regimes.",
    tech: ["Python", "PyTorch", "MoCo", "Contrastive Learning", "CIFAR-10"],
    category: "cv",
    status: "Completed",
    github: "https://github.com/SanyatFale/Term-Paper",
    paper: ""
  }
];

const categories = ["all", "ai", "nlp", "llm", "cv"];
const categoryLabels: Record<string, string> = {
  all: "all",
  ai: "AI / ML",
  nlp: "NLP",
  llm: "LLM / Agentic",
  cv: "Computer Vision"
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Projects — Sanyat Fale</title>
    <meta name="description" content="ML systems, NLP research, and agentic AI projects by Sanyat Fale." />
  </head>

  <body class="bg-black text-white font-mono">

    <!-- Navigation Header -->
    <header class="sticky top-0 z-40 bg-black/90 backdrop-blur-md border-b border-purple-900/30">
      <nav class="max-w-4xl mx-auto px-6 py-4 flex items-center">
        <a href="/" class="font-mono text-gray-400 hover:text-purple-400 transition-colors text-sm">
          ← .home()
        </a>
      </nav>
    </header>

    <section class="max-w-4xl mx-auto px-6 py-16">
      <h1 class="text-4xl font-bold font-mono mb-12 text-white">Projects</h1>

      <!-- Search and Filter Controls -->
      <div class="mb-10 space-y-4">
        <div class="relative">
          <input
            type="text"
            id="search-input"
            placeholder="search projects..."
            class="w-full bg-transparent border border-purple-900/40 rounded-none px-4 py-2 text-sm font-mono text-gray-300 placeholder-gray-600 focus:outline-none focus:border-purple-500 transition-colors"
          />
        </div>

        <div class="flex flex-wrap gap-2">
          {categories.map(cat => (
            <button
              class={`filter-btn px-3 py-1 text-xs font-mono rounded-sm transition-colors ${cat === 'all' ? 'bg-purple-600 text-white' : 'bg-transparent border border-purple-900/40 text-gray-400 hover:border-purple-500 hover:text-gray-200'}`}
              data-filter={cat}
            >
              {categoryLabels[cat]}
            </button>
          ))}
        </div>
      </div>

      <!-- Projects List -->
      <div id="projects-container" class="space-y-0">
        {projects.map((project, index) => (
          <article
            class="project-card border-t border-purple-900/20 py-8 group"
            data-category={project.category}
            data-title={project.title.toLowerCase()}
          >
            <div class="flex items-start gap-6">
              <!-- Index -->
              <span class="text-xs font-mono text-gray-700 w-6 shrink-0 pt-1">
                {String(index + 1).padStart(2, '0')}
              </span>

              <!-- Content -->
              <div class="flex-1 min-w-0">
                <div class="flex flex-wrap items-center gap-3 mb-2">
                  <h2 class="text-lg font-mono font-semibold text-gray-200 group-hover:text-purple-400 transition-colors">
                    {project.title}
                  </h2>
                  <span class={`text-xs font-mono px-2 py-0.5 rounded-sm shrink-0 ${
                    project.status === 'In Progress'
                      ? 'bg-yellow-900/30 text-yellow-500'
                      : 'bg-green-900/30 text-green-500'
                  }`}>
                    {project.status}
                  </span>
                </div>

                <p class="text-sm text-gray-500 leading-relaxed mb-4">
                  {project.description}
                </p>

                <div class="flex flex-wrap gap-2 mb-4">
                  {project.tech.map(t => (
                    <span class="text-xs font-mono text-gray-600 border border-purple-900/20 px-2 py-0.5 rounded-sm">
                      {t}
                    </span>
                  ))}
                </div>

                {(project.github || project.paper) && (
                  <div class="flex gap-4">
                    {project.github && (
                      <a href={project.github} class="text-xs font-mono text-purple-400 hover:underline" target="_blank" rel="noopener noreferrer">
                        → github
                      </a>
                    )}
                    {project.paper && (
                      <a href={project.paper} class="text-xs font-mono text-purple-400 hover:underline" target="_blank" rel="noopener noreferrer">
                        → paper
                      </a>
                    )}
                  </div>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- No results message -->
      <div id="no-results" class="hidden py-16 text-center">
        <p class="font-mono text-gray-600">no matching projects.</p>
      </div>
    </section>

    <!-- Contact footer -->
    <footer class="border-t border-purple-900/20 max-w-4xl mx-auto px-6 py-8">
      <p class="font-mono text-sm text-gray-600">
        interested in collaborating? <span id="projects-email-link"></span>
      </p>
    </footer>

    <script>
      // Email obfuscation — decoded client-side only
      (function() {
        const el = document.getElementById('projects-email-link');
        if (el) {
          const e = atob('c2FueWF0dmlub2RAaWlzYy5hYy5pbg==');
          el.innerHTML = '<a href="mailto:' + e + '" class="text-purple-400 hover:underline font-mono">' + e + '</a>';
        }
      })();

      // Search and filter
      document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('search-input') as HTMLInputElement | null;
        const filterButtons = document.querySelectorAll('.filter-btn');
        const projectCards = document.querySelectorAll('.project-card');
        const noResults = document.getElementById('no-results');

        let activeFilter = 'all';
        let searchQuery = '';

        function filterProjects() {
          let visibleCount = 0;

          projectCards.forEach(card => {
            const el = card as HTMLElement;
            const cardCategory = el.getAttribute('data-category') || '';
            const cardTitle = el.getAttribute('data-title') || '';

            const catMatch = activeFilter === 'all' || cardCategory === activeFilter;
            const searchMatch = searchQuery === '' || cardTitle.includes(searchQuery.toLowerCase());

            if (catMatch && searchMatch) {
              el.style.display = 'block';
              visibleCount++;
            } else {
              el.style.display = 'none';
            }
          });

          if (noResults) {
            noResults.classList.toggle('hidden', visibleCount > 0);
          }
        }

        filterButtons.forEach(button => {
          button.addEventListener('click', function(e) {
            const btn = e.currentTarget as HTMLElement;
            activeFilter = btn.getAttribute('data-filter') || 'all';

            filterButtons.forEach(b => {
              b.classList.remove('bg-purple-600', 'text-white');
              b.classList.add('bg-transparent', 'border', 'border-purple-900/40', 'text-gray-400');
            });
            btn.classList.add('bg-purple-600', 'text-white');
            btn.classList.remove('bg-transparent', 'text-gray-400');

            filterProjects();
          });
        });

        if (searchInput) {
          searchInput.addEventListener('input', function(e) {
            searchQuery = (e.currentTarget as HTMLInputElement).value;
            filterProjects();
          });
        }
      });
    </script>

    <style>
      :root {
        --purple: #a855f7;
        --bg: #000000;
        --light: #f3f4f6;
      }

      body {
        background-color: var(--bg);
        color: var(--light);
        font-family: 'Courier New', monospace;
      }
    </style>
  </body>
</html>
