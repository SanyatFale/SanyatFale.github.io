---
import "../styles/global.css";
import DarkModeToggle from "../components/DarkModeToggle.jsx";
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Projects - Digital Creations & Innovations</title>
    <meta name="description" content="Explore my latest projects, experiments, and digital creations that showcase the intersection of technology and creativity." />
  </head>

  <body class="bg-gray-50 text-gray-900 dark:bg-dark-900 dark:text-gray-100 font-sans overflow-x-hidden">
    <!-- Background Elements -->
    <div class="fixed inset-0 -z-10">
      <div class="absolute inset-0 bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 dark:from-dark-900 dark:via-blue-900/30 dark:to-indigo-900/20"></div>

      <!-- Floating geometric shapes -->
      <div class="absolute top-20 left-10 w-32 h-32 bg-gradient-to-r from-blue-400/20 to-purple-400/20 rounded-full blur-xl animate-pulse"></div>
      <div class="absolute top-40 right-20 w-24 h-24 bg-gradient-to-r from-purple-400/20 to-pink-400/20 rounded-full blur-xl animate-pulse delay-1000"></div>
      <div class="absolute bottom-40 left-20 w-40 h-40 bg-gradient-to-r from-indigo-400/20 to-blue-400/20 rounded-full blur-xl animate-pulse delay-2000"></div>

      <!-- Grid pattern overlay -->
      <div class="absolute inset-0 opacity-30 dark:opacity-20" style="background-image: radial-gradient(circle at 1px 1px, rgba(156,146,172,0.15) 1px, transparent 0); background-size: 20px 20px;"></div>
    </div>

    <!-- Dark Mode Toggle -->
    <DarkModeToggle client:load />

    <!-- Navigation -->
    <nav class="relative z-10 max-w-7xl mx-auto px-6 py-6">
      <div class="flex items-center justify-between">
        <a href="/" class="text-xl font-bold text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors">
          ← Back to Home
        </a>
        <div class="flex items-center gap-6">
          <a href="/blog" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Blog</a>
          <a href="/about" class="text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">About</a>
        </div>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative z-10 max-w-7xl mx-auto px-6 py-16">
      <div class="text-center space-y-6 mb-16">
        <h1 class="text-5xl md:text-6xl font-bold bg-gradient-to-r from-primary-600 to-indigo-600 dark:from-primary-400 dark:to-indigo-400 bg-clip-text text-transparent">
          My Projects
        </h1>
        <p class="text-xl text-gray-600 dark:text-gray-300 max-w-3xl mx-auto leading-relaxed">
          A showcase of digital creations, innovative solutions, and experimental ideas that push the boundaries of what's possible
        </p>

        <!-- Project stats -->
        <div class="flex flex-wrap justify-center gap-8 mt-8 text-sm text-gray-500 dark:text-gray-400">
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
            <span>12+ Active Projects</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 bg-blue-500 rounded-full"></div>
            <span>Open Source</span>
          </div>
          <div class="flex items-center gap-2">
            <div class="w-2 h-2 bg-purple-500 rounded-full"></div>
            <span>Continuously Updated</span>
          </div>
        </div>
      </div>

      <!-- Filter Tabs -->
      <div class="flex flex-wrap justify-center gap-2 mb-12">
        <button class="filter-btn active px-6 py-2 rounded-full bg-primary-600 text-white hover:bg-primary-700 transition-colors" data-filter="all">
          All Projects
        </button>
        <button class="filter-btn px-6 py-2 rounded-full bg-gray-200 dark:bg-dark-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-dark-600 transition-colors" data-filter="web">
          Web Apps
        </button>
        <button class="filter-btn px-6 py-2 rounded-full bg-gray-200 dark:bg-dark-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-dark-600 transition-colors" data-filter="tools">
          Developer Tools
        </button>
        <button class="filter-btn px-6 py-2 rounded-full bg-gray-200 dark:bg-dark-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-dark-600 transition-colors" data-filter="ai">
          AI/ML
        </button>
        <button class="filter-btn px-6 py-2 rounded-full bg-gray-200 dark:bg-dark-700 text-gray-700 dark:text-gray-300 hover:bg-gray-300 dark:hover:bg-dark-600 transition-colors" data-filter="experimental">
          Experimental
        </button>
      </div>

      <!-- Projects Grid -->
      <div class="grid gap-8 md:gap-12" id="projects-container">

        <!-- Featured Project -->
        <div class="project-card featured col-span-full" data-category="web">
          <div class="relative group bg-white/80 dark:bg-dark-800/80 backdrop-blur-sm rounded-2xl overflow-hidden border border-gray-200 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-300">
            <!-- Featured badge -->
            <div class="absolute top-4 left-4 z-10 px-3 py-1 bg-gradient-to-r from-yellow-400 to-orange-500 text-white text-sm font-medium rounded-full">
              ⭐ Featured
            </div>

            <div class="grid md:grid-cols-2 gap-0">
              <!-- Project Image/Demo -->
              <div class="relative h-64 md:h-80 bg-gradient-to-br from-primary-500 to-indigo-600 flex items-center justify-center">
                <div class="text-white text-6xl">🚀</div>
                <div class="absolute inset-0 bg-black/20 group-hover:bg-black/10 transition-colors duration-300"></div>
              </div>

              <!-- Project Info -->
              <div class="p-8 space-y-4">
                <div class="flex items-center gap-3">
                  <h2 class="text-2xl md:text-3xl font-bold text-gray-900 dark:text-white">Magical Mercury Website</h2>
                  <span class="px-2 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 text-xs rounded-full">Live</span>
                </div>

                <p class="text-gray-600 dark:text-gray-300 leading-relaxed">
                  A modern, responsive portfolio website built with Astro, React, and Tailwind CSS. Features dark mode, smooth animations, and a vinyl record audio player.
                </p>

                <!-- Tech Stack -->
                <div class="flex flex-wrap gap-2">
                  <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm rounded-full">Astro</span>
                  <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm rounded-full">React</span>
                  <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm rounded-full">Tailwind CSS</span>
                  <span class="px-3 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm rounded-full">Framer Motion</span>
                </div>

                <!-- Action Buttons -->
                <div class="flex gap-4 pt-4">
                  <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 hover:bg-primary-700 text-white rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                    </svg>
                    Live Demo
                  </a>
                  <a href="https://github.com/yourusername/magical-mercury" class="inline-flex items-center gap-2 px-6 py-3 border border-gray-300 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 text-gray-700 dark:text-gray-300 rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                    View Code
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Regular Project Cards Grid -->
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">

          <!-- PII Detection Toolkit -->
          <div class="project-card group" data-category="tools">
            <div class="relative bg-white/80 dark:bg-dark-800/80 backdrop-blur-sm rounded-xl overflow-hidden border border-gray-200 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-300 hover:shadow-xl">
              <!-- Project Image -->
              <div class="relative h-48 bg-gradient-to-br from-green-500 to-emerald-600 flex items-center justify-center">
                <div class="text-white text-4xl">🔍</div>
                <div class="absolute top-3 right-3 px-2 py-1 bg-white/20 backdrop-blur-sm text-white text-xs rounded-full">
                  Java
                </div>
              </div>

              <!-- Project Info -->
              <div class="p-6 space-y-4">
                <div class="flex items-center justify-between">
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white">PII Detection Toolkit</h3>
                  <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-xs rounded-full">Open Source</span>
                </div>

                <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
                  A fast and customizable Java library for identifying personal data in unstructured text with high accuracy.
                </p>

                <!-- Tech Stack -->
                <div class="flex flex-wrap gap-1">
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">Java</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">Maven</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">JUnit</span>
                </div>

                <!-- Action Buttons -->
                <div class="flex gap-2 pt-2">
                  <a href="https://github.com/yourusername/pii-toolkit" class="flex-1 text-center px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm rounded-lg transition-colors">
                    GitHub
                  </a>
                  <button class="px-4 py-2 border border-gray-300 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 text-gray-700 dark:text-gray-300 text-sm rounded-lg transition-colors">
                    Demo
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- AI Chat Assistant -->
          <div class="project-card group" data-category="ai">
            <div class="relative bg-white/80 dark:bg-dark-800/80 backdrop-blur-sm rounded-xl overflow-hidden border border-gray-200 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-300 hover:shadow-xl">
              <!-- Project Image -->
              <div class="relative h-48 bg-gradient-to-br from-purple-500 to-pink-600 flex items-center justify-center">
                <div class="text-white text-4xl">🤖</div>
                <div class="absolute top-3 right-3 px-2 py-1 bg-white/20 backdrop-blur-sm text-white text-xs rounded-full">
                  Python
                </div>
              </div>

              <!-- Project Info -->
              <div class="p-6 space-y-4">
                <div class="flex items-center justify-between">
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white">AI Chat Assistant</h3>
                  <span class="px-2 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 text-xs rounded-full">Live</span>
                </div>

                <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
                  An intelligent chatbot powered by OpenAI's GPT with context awareness and memory capabilities.
                </p>

                <!-- Tech Stack -->
                <div class="flex flex-wrap gap-1">
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">Python</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">OpenAI</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">FastAPI</span>
                </div>

                <!-- Action Buttons -->
                <div class="flex gap-2 pt-2">
                  <a href="#" class="flex-1 text-center px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm rounded-lg transition-colors">
                    Try Demo
                  </a>
                  <button class="px-4 py-2 border border-gray-300 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 text-gray-700 dark:text-gray-300 text-sm rounded-lg transition-colors">
                    Code
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Task Management App -->
          <div class="project-card group" data-category="web">
            <div class="relative bg-white/80 dark:bg-dark-800/80 backdrop-blur-sm rounded-xl overflow-hidden border border-gray-200 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-300 hover:shadow-xl">
              <!-- Project Image -->
              <div class="relative h-48 bg-gradient-to-br from-blue-500 to-cyan-600 flex items-center justify-center">
                <div class="text-white text-4xl">📋</div>
                <div class="absolute top-3 right-3 px-2 py-1 bg-white/20 backdrop-blur-sm text-white text-xs rounded-full">
                  React
                </div>
              </div>

              <!-- Project Info -->
              <div class="p-6 space-y-4">
                <div class="flex items-center justify-between">
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white">TaskFlow Pro</h3>
                  <span class="px-2 py-1 bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-300 text-xs rounded-full">In Progress</span>
                </div>

                <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
                  A modern task management application with real-time collaboration and advanced project tracking.
                </p>

                <!-- Tech Stack -->
                <div class="flex flex-wrap gap-1">
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">React</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">Node.js</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">MongoDB</span>
                </div>

                <!-- Action Buttons -->
                <div class="flex gap-2 pt-2">
                  <button class="flex-1 text-center px-4 py-2 bg-gray-400 text-white text-sm rounded-lg cursor-not-allowed">
                    Coming Soon
                  </button>
                  <button class="px-4 py-2 border border-gray-300 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 text-gray-700 dark:text-gray-300 text-sm rounded-lg transition-colors">
                    Preview
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Code Snippet Manager -->
          <div class="project-card group" data-category="tools">
            <div class="relative bg-white/80 dark:bg-dark-800/80 backdrop-blur-sm rounded-xl overflow-hidden border border-gray-200 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-300 hover:shadow-xl">
              <!-- Project Image -->
              <div class="relative h-48 bg-gradient-to-br from-orange-500 to-red-600 flex items-center justify-center">
                <div class="text-white text-4xl">💾</div>
                <div class="absolute top-3 right-3 px-2 py-1 bg-white/20 backdrop-blur-sm text-white text-xs rounded-full">
                  TypeScript
                </div>
              </div>

              <!-- Project Info -->
              <div class="p-6 space-y-4">
                <div class="flex items-center justify-between">
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white">SnippetVault</h3>
                  <span class="px-2 py-1 bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-xs rounded-full">Open Source</span>
                </div>

                <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
                  A powerful code snippet manager with syntax highlighting, tagging, and cloud synchronization.
                </p>

                <!-- Tech Stack -->
                <div class="flex flex-wrap gap-1">
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">TypeScript</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">Electron</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">SQLite</span>
                </div>

                <!-- Action Buttons -->
                <div class="flex gap-2 pt-2">
                  <a href="#" class="flex-1 text-center px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm rounded-lg transition-colors">
                    Download
                  </a>
                  <button class="px-4 py-2 border border-gray-300 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 text-gray-700 dark:text-gray-300 text-sm rounded-lg transition-colors">
                    GitHub
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- Neural Network Visualizer -->
          <div class="project-card group" data-category="experimental">
            <div class="relative bg-white/80 dark:bg-dark-800/80 backdrop-blur-sm rounded-xl overflow-hidden border border-gray-200 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-300 hover:shadow-xl">
              <!-- Project Image -->
              <div class="relative h-48 bg-gradient-to-br from-indigo-500 to-purple-600 flex items-center justify-center">
                <div class="text-white text-4xl">🧠</div>
                <div class="absolute top-3 right-3 px-2 py-1 bg-white/20 backdrop-blur-sm text-white text-xs rounded-full">
                  WebGL
                </div>
              </div>

              <!-- Project Info -->
              <div class="p-6 space-y-4">
                <div class="flex items-center justify-between">
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white">Neural Viz</h3>
                  <span class="px-2 py-1 bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 text-xs rounded-full">Experimental</span>
                </div>

                <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
                  Interactive 3D visualization of neural networks with real-time training progress and layer analysis.
                </p>

                <!-- Tech Stack -->
                <div class="flex flex-wrap gap-1">
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">Three.js</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">WebGL</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">TensorFlow.js</span>
                </div>

                <!-- Action Buttons -->
                <div class="flex gap-2 pt-2">
                  <a href="#" class="flex-1 text-center px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm rounded-lg transition-colors">
                    Try Demo
                  </a>
                  <button class="px-4 py-2 border border-gray-300 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 text-gray-700 dark:text-gray-300 text-sm rounded-lg transition-colors">
                    Learn More
                  </button>
                </div>
              </div>
            </div>
          </div>

          <!-- API Documentation Generator -->
          <div class="project-card group" data-category="tools">
            <div class="relative bg-white/80 dark:bg-dark-800/80 backdrop-blur-sm rounded-xl overflow-hidden border border-gray-200 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 transition-all duration-300 hover:shadow-xl">
              <!-- Project Image -->
              <div class="relative h-48 bg-gradient-to-br from-teal-500 to-green-600 flex items-center justify-center">
                <div class="text-white text-4xl">📚</div>
                <div class="absolute top-3 right-3 px-2 py-1 bg-white/20 backdrop-blur-sm text-white text-xs rounded-full">
                  Go
                </div>
              </div>

              <!-- Project Info -->
              <div class="p-6 space-y-4">
                <div class="flex items-center justify-between">
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white">DocuGen</h3>
                  <span class="px-2 py-1 bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300 text-xs rounded-full">Live</span>
                </div>

                <p class="text-gray-600 dark:text-gray-300 text-sm leading-relaxed">
                  Automatically generate beautiful API documentation from code comments with interactive examples.
                </p>

                <!-- Tech Stack -->
                <div class="flex flex-wrap gap-1">
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">Go</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">Markdown</span>
                  <span class="px-2 py-1 bg-gray-100 dark:bg-dark-700 text-gray-600 dark:text-gray-300 text-xs rounded">Docker</span>
                </div>

                <!-- Action Buttons -->
                <div class="flex gap-2 pt-2">
                  <a href="#" class="flex-1 text-center px-4 py-2 bg-primary-600 hover:bg-primary-700 text-white text-sm rounded-lg transition-colors">
                    Try Online
                  </a>
                  <button class="px-4 py-2 border border-gray-300 dark:border-dark-600 hover:border-primary-300 dark:hover:border-primary-600 text-gray-700 dark:text-gray-300 text-sm rounded-lg transition-colors">
                    Install
                  </button>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <!-- Call to Action -->
      <div class="text-center mt-16 space-y-6">
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white">
          Interested in Collaborating?
        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300 max-w-2xl mx-auto">
          I'm always excited to work on new projects and explore innovative ideas. Let's build something amazing together!
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="/about" class="inline-flex items-center gap-2 px-8 py-3 bg-primary-600 hover:bg-primary-700 text-white rounded-lg transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
            Get in Touch
          </a>
