---
import "../styles/global.css";

export interface Props {
  title: string;
  pubDate: string;
  description: string;
  tags?: string[];
  thumbnail?: string;
  readingTime?: string;
}

const { title, pubDate, description, tags = [], thumbnail, readingTime } = Astro.props;
const formattedDate = new Date(pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {thumbnail && <meta property="og:image" content={thumbnail} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
  </head>

  <body class="bg-black text-white font-mono">

    <!-- Navigation Header -->
    <header class="sticky top-0 z-40 bg-black/90 backdrop-blur-md border-b border-purple-900/30">
      <nav class="max-w-4xl mx-auto px-6 py-4">
        <a href="/" class="font-mono text-gray-400 hover:text-purple-400 transition-colors text-sm">
          ← .home()
        </a>
      </nav>
    </header>

    <!-- Article -->
    <article class="max-w-4xl mx-auto px-6 py-12">

      <!-- Article Header -->
      <header class="mb-12">
        <div class="mb-4 flex items-center gap-4">
          <time class="text-xs font-mono text-gray-600 uppercase tracking-wide">
            {formattedDate}
          </time>
          {readingTime && (
            <>
              <span class="text-gray-700">·</span>
              <span class="text-xs font-mono text-gray-600">{readingTime}</span>
            </>
          )}
        </div>

        <h1 class="text-3xl md:text-4xl font-bold font-mono leading-tight mb-6 text-white">
          {title}
        </h1>

        <p class="text-gray-400 leading-relaxed font-mono text-sm">
          {description}
        </p>

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-6">
            {tags.map(tag => (
              <span class="text-xs font-mono text-gray-600">#{tag}</span>
            ))}
          </div>
        )}
      </header>

      <!-- Thumbnail Image -->
      {thumbnail && (
        <div class="mb-12 rounded-sm overflow-hidden">
          <img
            src={thumbnail}
            alt={title}
            class="w-full h-64 md:h-80 object-cover"
          />
        </div>
      )}

      <!-- Article Content -->
      <div class="prose prose-invert prose-sm md:prose-base max-w-none font-mono
                  prose-headings:font-bold prose-headings:text-white
                  prose-p:text-gray-300 prose-p:leading-relaxed
                  prose-a:text-purple-400 prose-a:no-underline hover:prose-a:underline
                  prose-blockquote:border-l-2 prose-blockquote:border-purple-500 prose-blockquote:bg-purple-950/20 prose-blockquote:py-2 prose-blockquote:px-4
                  prose-code:bg-purple-950/30 prose-code:text-purple-300 prose-code:px-1 prose-code:py-0.5 prose-code:rounded-sm prose-code:text-sm
                  prose-pre:bg-gray-950 prose-pre:border prose-pre:border-purple-900/30
                  prose-img:rounded-sm
                  prose-hr:border-purple-900/30">
        <slot />
      </div>

      <!-- Article Footer -->
      <footer class="mt-16 pt-8 border-t border-purple-900/20">
        <a href="/blog" class="font-mono text-sm text-gray-500 hover:text-purple-400 transition-colors">
          ← back to blog
        </a>
      </footer>
    </article>

    <style>
      :root {
        --purple: #a855f7;
        --bg: #000000;
        --light: #f3f4f6;
      }

      body {
        background-color: var(--bg);
        color: var(--light);
        font-family: 'Courier New', monospace;
      }
    </style>
  </body>
</html>
